# Notion API — get from https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database IDs — grab from each database's URL
# URL format: notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DAILY_LOG_DB_ID=
NOTION_HABITS_DB_ID=
NOTION_TASKS_DB_ID=
NOTION_PROJECTS_DB_ID=
NOTION_NOTES_DB_ID=
NOTION_RESOURCES_DB_ID=

# Phase 2 — fill after running: node tools/setup-new-dbs.js
NOTION_MEETSOLIS_STORIES_DB_ID=
NOTION_MEETSOLIS_BUGS_DB_ID=
NOTION_MEETSOLIS_DECISIONS_DB_ID=
